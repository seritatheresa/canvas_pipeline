# ============================================================
# Canvas Pipeline — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------ ValleyPROD Oracle Database (ODBC) ------
# Direct Oracle connection via Windows ODBC driver (no pre-configured DSN required).
# VALLEYPROD_ODBC_DRIVER — name of the Oracle ODBC driver installed on your machine.
#   To find it: ODBC Data Sources → Drivers tab. Common values:
#     Oracle in OraClient12Home1   (Oracle 12c client)
#     Oracle in OraClient19Home1   (Oracle 19c client)
#     Oracle in instantclient_21   (Oracle Instant Client)
VALLEYPROD_ODBC_DRIVER=Oracle in OraClient12Home1
VALLEYPROD_HOST=your_oracle_host
VALLEYPROD_PORT=1521
VALLEYPROD_SERVICE=ValleyPROD
VALLEYPROD_USER=your_db_username
VALLEYPROD_PASSWORD=your_db_password

# ------ Canvas LMS ------
# Production URL (no trailing slash)
CANVAS_URL=https://mvsu.instructure.com
# Admin API token (Settings → Approved Integrations → New Access Token)
CANVAS_TOKEN=your_canvas_api_token_here
# Root account ID (almost always 1)
CANVAS_ACCOUNT_ID=1
# Authentication provider ID for SSO logins (108 at MVSU)
CANVAS_AUTH_PROVIDER_ID=108

# ------ Pipeline behaviour ------
# Directory where generated CSV/ZIP files are written before upload
OUTPUT_DIR=./output
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
